#!/usr/bin/env bash
set -euo pipefail

PVM_HOME="${PVM_HOME:-$HOME/.local/pvm}"
PVM_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/pvm"
PVM_GLOBAL_FILE="$PVM_CONFIG/global"
PVM_LOCAL_FILE=".php-version"

mkdir -p "$PVM_HOME/shims" "$PVM_CONFIG"

usage() {
  cat <<'EOF'
Usage:
  pvm install VERSION [--with-extensions EXT...]
  pvm use VERSION
  pvm use --local VERSION
  pvm current

Supported versions: 5.6, 7.0-7.4, 8.0-8.6

Configure PATH once in your shell:
  export PATH="$HOME/.local/pvm/shims:/path/to/pvm/bin:$PATH"
EOF
}

validate_version() {
  case "$1" in
    5.6|7.0|7.1|7.2|7.3|7.4|8.0|8.1|8.2|8.3|8.4|8.5|8.6)
      ;;
    *)
      echo "Invalid version: $1" >&2
      exit 2
      ;;
  esac
}

require_brew() {
  if ! command -v brew >/dev/null 2>&1; then
    echo "brew not found in PATH; install/configure Homebrew to use pvm" >&2
    exit 1
  fi
}

bin_for_version() {
  require_brew
  echo "$(brew --prefix)/opt/php@$1/bin/php"
}

validate_extension() {
  case "$1" in
    ""|*[!A-Za-z0-9_-]*)
      echo "Invalid extension: $1" >&2
      exit 2
      ;;
  esac
}

find_local_version() {
  local dir="$PWD"

  while [ "$dir" != "/" ]; do
    if [ -f "$dir/$PVM_LOCAL_FILE" ]; then
      cat "$dir/$PVM_LOCAL_FILE"
      return 0
    fi
    dir="$(dirname "$dir")"
  done

  return 1
}

current_version() {
  if find_local_version >/dev/null; then
    find_local_version
  elif [ -f "$PVM_GLOBAL_FILE" ]; then
    cat "$PVM_GLOBAL_FILE"
  else
    echo "8.2"
  fi
}

write_php_shim() {
  mkdir -p "$PVM_HOME/shims"

  cat > "$PVM_HOME/shims/php" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

PVM_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/pvm"
PVM_GLOBAL_FILE="$PVM_CONFIG/global"
PVM_LOCAL_FILE=".php-version"

validate_version() {
  case "$1" in
    5.6|7.0|7.1|7.2|7.3|7.4|8.0|8.1|8.2|8.3|8.4|8.5|8.6)
      ;;
    *)
      echo "Invalid PHP version" >&2
      exit 2
      ;;
  esac
}

require_brew() {
  if ! command -v brew >/dev/null 2>&1; then
    echo "brew not found in PATH; install/configure Homebrew to use pvm" >&2
    exit 1
  fi
}

find_local_version() {
  local dir="$PWD"

  while [ "$dir" != "/" ]; do
    if [ -f "$dir/$PVM_LOCAL_FILE" ]; then
      cat "$dir/$PVM_LOCAL_FILE"
      return 0
    fi
    dir="$(dirname "$dir")"
  done

  return 1
}

current_version() {
  if find_local_version >/dev/null; then
    find_local_version
  elif [ -f "$PVM_GLOBAL_FILE" ]; then
    cat "$PVM_GLOBAL_FILE"
  else
    echo "8.2"
  fi
}

run_php() {
  local version="$1"
  local binary
  shift

  validate_version "$version"
  require_brew
  binary="$(brew --prefix)/opt/php@$version/bin/php"
  if [ ! -x "$binary" ]; then
    echo "PHP $version is not installed at $binary; run: pvm install $version" >&2
    exit 127
  fi

  exec "$binary" "$@"
}

run_php "$(current_version)" "$@"
EOF

  chmod +x "$PVM_HOME/shims/php"
}

brew_php_formula() {
  echo "shivammathur/php/php@$1"
}

brew_extension_formula() {
  echo "shivammathur/extensions/$1@$2"
}

is_builtin_extension() {
  local version="$1"
  local extension="$2"
  local binary
  local modules

  binary="$(bin_for_version "$version")"
  if [ ! -x "$binary" ]; then
    return 1
  fi

  modules="$("$binary" -m | tr '[:upper:]' '[:lower:]')"
  case "$extension" in
    mysql)
      printf '%s\n' "$modules" | grep -qx 'mysqli' \
        && printf '%s\n' "$modules" | grep -qx 'pdo_mysql'
      ;;
    *)
      printf '%s\n' "$modules" | grep -qx "$extension"
      ;;
  esac
}

install_version() {
  local version="${1:-}"
  local extensions=()
  local extension
  local normalized_extension

  validate_version "$version"

  shift || true
  case "${1:-}" in
    "")
      ;;
    --with-extensions)
      shift
      if [ "$#" -eq 0 ]; then
        echo "Provide at least one extension after --with-extensions" >&2
        exit 2
      fi

      while [ "$#" -gt 0 ]; do
        validate_extension "$1"
        normalized_extension="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')"
        extensions+=("$normalized_extension")
        shift
      done
      ;;
    *)
      echo "Invalid install argument: $1" >&2
      exit 2
      ;;
  esac

  require_brew

  brew tap shivammathur/php
  brew install "$(brew_php_formula "$version")"

  if [ "${#extensions[@]}" -gt 0 ]; then
    brew tap shivammathur/extensions
  fi

  for extension in "${extensions[@]}"; do
    if is_builtin_extension "$version" "$extension"; then
      echo "Extension $extension is already available in PHP $version"
      continue
    fi

    if brew install "$(brew_extension_formula "$extension" "$version")"; then
      continue
    fi

    if is_builtin_extension "$version" "$extension"; then
      echo "Extension $extension is already available in PHP $version"
      continue
    fi

    echo "Failed to install extension $extension for PHP $version" >&2
    exit 1
  done

  write_php_shim
}

use_version() {
  local scope="global"
  local version=""

  case "${1:-}" in
    --local)
      scope="local"
      version="${2:-}"
      ;;
    *)
      version="${1:-}"
      ;;
  esac

  validate_version "$version"
  write_php_shim

  if [ "$scope" = "local" ]; then
    echo "$version" > "$PVM_LOCAL_FILE"
    echo "Local PHP version set to $version in $PWD/$PVM_LOCAL_FILE"
  else
    echo "$version" > "$PVM_GLOBAL_FILE"
    echo "Global PHP version set to $version"
  fi
}

case "${1:-}" in
  install)
    shift
    install_version "$@"
    ;;

  use)
    shift
    use_version "$@"
    ;;

  current)
    version="$(current_version)"
    validate_version "$version"
    bin="$(bin_for_version "$version")"
    echo "$version -> $bin"
    ;;

  *)
    usage
    exit 2
    ;;
esac
